<?xml version="1.0" encoding="utf-8"?>
<!-- Giriş ekranı tasarımı -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center_vertical">

    <!-- Geri butonu -->
    <ImageButton
        android:id="@+id/btnBackToMain"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_back"
        android:background="@drawable/btn_circle_dark"
        android:tint="@color/white"
        android:layout_marginBottom="32dp"
        android:onClick="finish"/>

    <!-- Başlık -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tekrar\nHoş Geldin"
        android:textColor="@color/white"
        android:textSize="32sp"
        android:textStyle="bold"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="8dp"/>

    <!-- Alt açıklama -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Notlarına devam etmek için giriş yap"
        android:textColor="@color/gray"
        android:textSize="14sp"
        android:layout_marginBottom="40dp"/>

    <!-- Kullanıcı adı etiketi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kullanıcı Adı"
        android:textColor="@color/gray"
        android:textSize="12sp"
        android:layout_marginBottom="6dp"/>

    <!-- Kullanıcı adı giriş alanı -->
    <EditText
        android:id="@+id/etUsername"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="kullaniciadi"
        android:textColor="@color/white"
        android:textColorHint="@color/hint"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="text"
        android:imeOptions="actionNext"
        android:singleLine="true"
        android:layout_marginBottom="16dp"/>

    <!-- Şifre etiketi -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Şifre"
        android:textColor="@color/gray"
        android:textSize="12sp"
        android:layout_marginBottom="6dp"/>

    <!-- Şifre giriş alanı -->
    <EditText
        android:id="@+id/etPassword"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:hint="••••••••"
        android:textColor="@color/white"
        android:textColorHint="@color/hint"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textPassword"
        android:imeOptions="actionDone"
        android:singleLine="true"
        android:layout_marginBottom="28dp"/>

    <!-- Giriş yap butonu -->
    <Button
        android:id="@+id/btnLogin"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Giriş Yap"
        android:textColor="#000000"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="@color/white"
        android:textAllCaps="false"/>

    <!-- Kayıt ol yönlendirme alanı -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="24dp">

        <!-- Hesap yok yazısı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hesabın yok mu?  "
            android:textColor="@color/gray"
            android:textSize="14sp"/>

        <!-- Kayıt ol linki -->
        <TextView
            android:id="@+id/tvGoRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kayıt Ol"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"/>
    </LinearLayout>

</LinearLayout>
