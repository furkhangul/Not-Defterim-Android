<?xml version="1.0" encoding="utf-8"?>

<!-- Not düzenleme / oluşturma ekranı -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Üst bar (geri, sil, kaydet) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="44dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <!-- Geri butonu -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/btn_circle_dark"
            android:tint="@color/white"
            android:contentDescription="Geri"/>

        <!-- Boşluk doldurucu -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Sil butonu -->
        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_delete"
            android:background="@drawable/btn_circle_dark"
            android:tint="#FF6B6B"
            android:layout_marginEnd="8dp"
            android:contentDescription="Sil"
            android:visibility="gone"/>

        <!-- Kaydet butonu -->
        <ImageButton
            android:id="@+id/btnSave"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_check"
            android:background="@drawable/btn_circle_white"
            android:tint="#000000"
            android:contentDescription="Kaydet"/>

    </LinearLayout>

    <!-- Not tarihi -->
    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray"
        android:textSize="12sp"
        android:paddingStart="20dp"
        android:layout_marginBottom="8dp"/>

    <!-- Not başlığı -->
    <EditText
        android:id="@+id/etTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Başlık"
        android:textColor="@color/white"
        android:textColorHint="@color/hint"
        android:textSize="24sp"
        android:textStyle="bold"
        android:background="@null"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:inputType="text|textCapSentences"
        android:imeOptions="actionNext"
        android:singleLine="true"/>

    <!-- Ayırıcı çizgi -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="12dp"/>

    <!-- Not içeriği -->
    <EditText
        android:id="@+id/etContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Notunu buraya yaz..."
        android:textColor="@color/white"
        android:textColorHint="@color/hint"
        android:textSize="16sp"
        android:lineSpacingExtra="6dp"
        android:background="@null"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp"
        android:inputType="textMultiLine|textCapSentences"
        android:gravity="top"/>

    <!-- Renk seçim alanı -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp"
        android:background="#0D0D0D">

        <!-- Renk seçenekleri -->
        <View android:id="@+id/color0"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/color_circle_0"
            android:layout_margin="6dp"/>
        <View android:id="@+id/color1"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/color_circle_1"
            android:layout_margin="6dp"/>
        <View android:id="@+id/color2"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/color_circle_2"
            android:layout_margin="6dp"/>
        <View android:id="@+id/color3"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/color_circle_3"
            android:layout_margin="6dp"/>
        <View android:id="@+id/color4"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/color_circle_4"
            android:layout_margin="6dp"/>
        <View android:id="@+id/color5"
            android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/color_circle_5"
            android:layout_margin="6dp"/>

    </LinearLayout>

</LinearLayout>
