<?xml version="1.0" encoding="utf-8"?>

<!-- Kayıt olma ekranı -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <!-- Form alanlarını tutan ana layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center_vertical">

        <!-- Başlık -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hesap\nOluştur"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="8dp"/>

        <!-- Alt açıklama -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Notlarını güvende tutmak için kaydol"
            android:textColor="@color/gray"
            android:textSize="14sp"
            android:layout_marginBottom="40dp"/>

        <!-- Ad soyad etiketi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ad Soyad"
            android:textColor="@color/gray"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Ad soyad giriş alanı -->
        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Adın ve soyadın"
            android:textColor="@color/white"
            android:textColorHint="@color/hint"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPersonName|textCapWords"
            android:imeOptions="actionNext"
            android:singleLine="true"
            android:layout_marginBottom="16dp"/>

        <!-- Kullanıcı adı etiketi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kullanıcı Adı"
            android:textColor="@color/gray"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Kullanıcı adı giriş alanı -->
        <EditText
            android:id="@+id/etUsername"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="En az 3 karakter"
            android:textColor="@color/white"
            android:textColorHint="@color/hint"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionNext"
            android:singleLine="true"
            android:layout_marginBottom="16dp"/>

        <!-- Şifre etiketi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şifre"
            android:textColor="@color/gray"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Şifre giriş alanı -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="En az 4 karakter"
            android:textColor="@color/white"
            android:textColorHint="@color/hint"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:imeOptions="actionNext"
            android:singleLine="true"
            android:layout_marginBottom="16dp"/>

        <!-- Şifre tekrar etiketi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Şifre Tekrar"
            android:textColor="@color/gray"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Şifre tekrar giriş alanı -->
        <EditText
            android:id="@+id/etPasswordConfirm"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:hint="Şifreni tekrar gir"
            android:textColor="@color/white"
            android:textColorHint="@color/hint"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="textPassword"
            android:imeOptions="actionDone"
            android:singleLine="true"
            android:layout_marginBottom="28dp"/>

        <!-- Kayıt ol butonu -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Kayıt Ol"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/white"
            android:textAllCaps="false"/>

        <!-- Giriş ekranına yönlendirme -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp">

            <!-- Bilgi yazısı -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Zaten hesabın var mı?  "
                android:textColor="@color/gray"
                android:textSize="14sp"/>

            <!-- Giriş yap linki -->
            <TextView
                android:id="@+id/tvGoLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Giriş Yap"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
